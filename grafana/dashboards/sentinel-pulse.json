{
  "title": "Sentinel Pulse - Trading Bot",
  "uid": "sentinel-pulse",
  "tags": ["sentinel-pulse", "trading"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row", "title": "ROW 1: BOT STATUS", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}
    },
    {
      "id": 1, "type": "stat", "title": "Bot Status",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "description": "Green = Bot is running. Red = Bot is stopped.",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_running", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "STOPPED"}, "1": {"text": "RUNNING"}}}], "thresholds": {"steps": [{"color": "red"}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "background"}
    },
    {
      "id": 2, "type": "stat", "title": "Trading Mode",
      "gridPos": {"x": 4, "y": 1, "w": 6, "h": 4},
      "description": "LIVE = real money, PAPER = simulation",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_simulate_24_7", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "LIVE"}, "1": {"text": "PAPER"}}}], "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 1}]}}},
      "options": {"colorMode": "background"}
    },
    {
      "id": 3, "type": "stat", "title": "Market Status",
      "gridPos": {"x": 10, "y": 1, "w": 6, "h": 4},
      "description": "Market open/closed based on market hours",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_market_open", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "CLOSED"}, "1": {"text": "OPEN"}}}], "thresholds": {"steps": [{"color": "gray"}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "background"}
    },
    {
      "id": 4, "type": "stat", "title": "Demo Mode",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "description": "Running without MongoDB",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_demo_mode", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "PROD"}, "1": {"text": "DEMO"}}}], "thresholds": {"steps": [{"color": "green"}, {"color": "blue", "value": 1}]}}},
      "options": {"colorMode": "background"}
    },
    {
      "id": 5, "type": "stat", "title": "Active Tickers",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "description": "Number of tickers with enabled trading",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_tickers", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [], "thresholds": {"steps": [{"color": "gray"}, {"color": "yellow", "value": 1}, {"color": "green", "value": 3}]}}},
      "options": {"colorMode": "background"}
    },
    {
      "type": "row", "title": "ROW 2: CAPITAL", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}
    },
    {
      "id": 10, "type": "gauge", "title": "Account Balance",
      "gridPos": {"x": 0, "y": 6, "w": 8, "h": 6},
      "description": "Total account balance configured",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_account_balance", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "mappings": [], "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 1000}, {"color": "green", "value": 10000}]}}}
    },
    {
      "id": 11, "type": "gauge", "title": "Allocated",
      "gridPos": {"x": 8, "y": 6, "w": 8, "h": 6},
      "description": "Total buy power allocated across tickers",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_allocated", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "mappings": [], "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 5000}, {"color": "red", "value": 10000}]}}}
    },
    {
      "id": 12, "type": "gauge", "title": "Available",
      "gridPos": {"x": 16, "y": 6, "w": 8, "h": 6},
      "description": "Account Balance minus Allocated",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_available", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "mappings": [], "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 100}, {"color": "green", "value": 1000}]}}}
    },
    {
      "type": "row", "title": "ROW 3: TRADING", "gridPos": {"x": 0, "y": 12, "w": 24, "h": 1}
    },
    {
      "id": 20, "type": "stat", "title": "Today's Trades",
      "gridPos": {"x": 0, "y": 13, "w": 4, "h": 4},
      "description": "Total trades executed today",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_trades_today", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [], "thresholds": {"steps": [{"color": "gray"}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "background"}
    },
    {
      "id": 21, "type": "stat", "title": "Wins",
      "gridPos": {"x": 4, "y": 13, "w": 4, "h": 4},
      "description": "Winning trades today",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_wins_today", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [], "thresholds": {"steps": [{"color": "gray"}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 22, "type": "stat", "title": "Losses",
      "gridPos": {"x": 8, "y": 13, "w": 4, "h": 4},
      "description": "Losing trades today",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_losses_today", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [], "thresholds": {"steps": [{"color": "gray"}, {"color": "red", "value": 1}]}}},
      "options": {"colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 23, "type": "gauge", "title": "Win Rate",
      "gridPos": {"x": 12, "y": 13, "w": 6, "h": 4},
      "description": "Win rate today",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_win_rate", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "mappings": [], "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.4}, {"color": "green", "value": 0.6}]}}}
    },
    {
      "id": 24, "type": "gauge", "title": "Today's P&L",
      "gridPos": {"x": 18, "y": 13, "w": 6, "h": 4},
      "description": "Profit/Loss today",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_pnl_today", "instant": true, "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "mappings": [], "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "gray", "value": 0}, {"color": "green", "value": 0}]}}},
      "options": {"colorMode": "background"}
    },
    {
      "type": "row", "title": "ROW 4: BROKERS", "gridPos": {"x": 0, "y": 17, "w": 24, "h": 1}
    },
    {
      "id": 30, "type": "table", "title": "Broker Health",
      "gridPos": {"x": 0, "y": 18, "w": 24, "h": 8},
      "description": "Broker connection status",
      "datasource": {"uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sentinel_pulse_broker_health", "instant": true, "refId": "A"}],
      "transform": "table",
      "options": {"showHeader": true}
    }
  ]
}